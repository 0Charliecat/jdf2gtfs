{
	"name": "jdf2gtfs",
	"description": "a nodejs script and dependency to convert Czechoslovak JDF timetable format to GTFS",
	"version": "2.0.0",
	"main": "index.js",
	"types": "index.d.ts",
	"license": "SEE LICENSE IN LICENSE",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"files": [
		"index.js",
		"index.js.map",
		"index.d.ts",
		"Library/**/*.d.ts"
	],
	"dependencies": {
		"@fast-csv/parse": "^5.0.2",
		"@isithere/gtfs": "1.1.0-next-04",
		"iconv-lite": "^0.6.3",
		"json-2-csv": "^4.1.1",
		"jszip": "^3.10.1",
		"neat-csv": "^7.0.0",
		"slovak-holidays": "^1.0.1"
	},
	"scripts": {
		"prepublishOnly": "find . -maxdepth 6 -name '*.d.ts' -not -path './node_modules/*' -delete && bun build index.ts --outdir=. --sourcemap=external --packages=external --minify && tsc --project tsconfig.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/0Charliecat/jdf2gtfs.git"
	},
	"keywords": [
		"jdf",
		"gtfs"
	],
	"author": "charliecat",
	"bugs": {
		"url": "https://github.com/0Charliecat/jdf2gtfs/issues"
	},
	"homepage": "https://github.com/0Charliecat/jdf2gtfs#readme",
	"devDependencies": {
		"@types/adm-zip": "^0.5.7",
		"@types/node": "^22.10.7",
		"typescript": "^5.7.3"
	}
}
